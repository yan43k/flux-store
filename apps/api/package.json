{
  "name": "@flux/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prisma:validate": "prisma validate",
    "seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "render:build": "bash ../../scripts/render-build-api.sh"
  },
  "dependencies": {
    "@flux/shared": "0.1.0",
    "@prisma/adapter-mssql": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "latest",
    "bcrypt": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "helmet": "latest",
    "jsonwebtoken": "latest",
    "morgan": "latest",
    "pg": "^8.22.0",
    "zod": "latest",
    "@types/bcrypt": "latest",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/morgan": "latest",
    "@types/node": "latest",
    "@types/pg": "^8.20.0",
    "typescript": "latest"
  },
  "devDependencies": {
    "prisma": "latest",
    "tsx": "latest"
  }
}
