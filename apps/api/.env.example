PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
AUTH_MODE=prisma
# Windows-вход из Node.js часто не работает — используйте SQL-логин (см. scripts/setup-sqlserver.ps1).
DB_INTEGRATED_SECURITY=false
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=flux_store
DB_USER=flux_app
DB_PASSWORD=FluxStore2026!
DATABASE_URL="sqlserver://localhost:1433;database=flux_store;user=flux_app;password=FluxStore2026!;encrypt=true;trustServerCertificate=true"
JWT_ACCESS_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
